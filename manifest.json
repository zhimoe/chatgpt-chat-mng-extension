{
  "manifest_version": 3,
  "name": "ChatGPT 会话批量管理",
  "version": "1.0.0",
  "description": "在 chatgpt.com 左侧历史会话列表中启用多选和批量删除。",
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*"
  ]
}
